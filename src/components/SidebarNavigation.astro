---
interface MarkdownHeading {
    readonly depth: number;
    readonly slug: string;
    readonly text: string;
}

interface Props {
    readonly headings?: readonly MarkdownHeading[];
    readonly homeHref: string;
    readonly showHomeLink?: boolean;
    readonly title: string;
}

const {headings = [], homeHref, showHomeLink = true, title} = Astro.props;

const navigationHeadings = headings.filter(({depth}) => depth === 2 || depth === 3).slice(1);
const hasContents = navigationHeadings.length > 1;
---

{
    (showHomeLink || hasContents) && (
        <aside
            class="sidebar-navigation"
            aria-label={`Навигация: ${title}`}
        >
            <nav class="sidebar-navigation__panel">
                <div class="sidebar-navigation__header">
                    {showHomeLink && (
                        <a
                            class="sidebar-navigation__home"
                            href={homeHref}
                            aria-label="На главную"
                        >
                            <svg
                                aria-hidden="true"
                                viewBox="0 0 24 24"
                            >
                                <path d="M3 10.75 12 3l9 7.75V21a1 1 0 0 1-1 1h-5v-7H9v7H4a1 1 0 0 1-1-1V10.75Z" />
                            </svg>
                            <span class="sidebar-navigation__home-label">Главная</span>
                        </a>
                    )}

                    {hasContents && (
                        <button
                            class="sidebar-navigation__toggle"
                            type="button"
                            aria-controls="sidebar-navigation-content"
                            aria-expanded="false"
                            data-navigation-toggle
                        >
                            <span
                                class="sidebar-navigation__toggle-icon"
                                aria-hidden="true"
                            >
                                <span />
                                <span />
                                <span />
                            </span>

                            <span class="sidebar-navigation__title">Оглавление</span>
                        </button>
                    )}
                </div>

                {hasContents && (
                    <div
                        class="sidebar-navigation__rail"
                        aria-hidden="true"
                    >
                        {navigationHeadings.map(({slug}) => (
                            <span
                                class="sidebar-navigation__marker"
                                data-heading-marker={slug}
                            />
                        ))}
                    </div>
                )}

                {hasContents && (
                    <div
                        class="sidebar-navigation__content"
                        id="sidebar-navigation-content"
                    >
                        <ul class="sidebar-navigation__list">
                            {navigationHeadings.map(({depth, slug, text}) => (
                                <li>
                                    <a
                                        class={`sidebar-navigation__link sidebar-navigation__link--depth-${depth}`}
                                        href={`#${slug}`}
                                        data-heading-link={slug}
                                    >
                                        {text}
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </div>
                )}
            </nav>
        </aside>
    )
}

<script>
    let navigationController: AbortController | undefined;

    const initNavigation = (navigation: HTMLElement, signal: AbortSignal): void => {
        const panel = navigation.querySelector<HTMLElement>('.sidebar-navigation__panel');
        const toggle = navigation.querySelector<HTMLButtonElement>('[data-navigation-toggle]');

        if (!panel || !toggle) {
            return;
        }

        const links = [...navigation.querySelectorAll<HTMLAnchorElement>('[data-heading-link]')];

        const markers = [...navigation.querySelectorAll<HTMLElement>('[data-heading-marker]')];

        const headings = links.flatMap((link) => {
            const slug = link.dataset.headingLink;
            const heading = slug ? document.getElementById(slug) : null;

            return slug && heading ? [{slug, heading}] : [];
        });

        let animationFrame = 0;

        const setOpen = (open: boolean): void => {
            panel.toggleAttribute('data-open', open);
            toggle.setAttribute('aria-expanded', String(open));
        };

        const setActive = (activeSlug: string | undefined): void => {
            for (const link of links) {
                const isActive = link.dataset.headingLink === activeSlug;

                if (isActive) {
                    link.setAttribute('aria-current', 'location');
                } else {
                    link.removeAttribute('aria-current');
                }
            }

            for (const marker of markers) {
                marker.toggleAttribute('data-active', marker.dataset.headingMarker === activeSlug);
            }
        };

        const getAnchorOffset = (): number =>
            Number.parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--anchor-offset')) || 0;

        const getActiveSlug = (): string | undefined => {
            let activeSlug = headings[0]?.slug;
            const offset = getAnchorOffset();
            const roundingTolerance = 1;
            const remainingScroll = document.documentElement.scrollHeight - window.innerHeight - window.scrollY;
            const isAtPageBottom = window.scrollY > 0 && remainingScroll <= roundingTolerance;

            if (isAtPageBottom) {
                return headings.at(-1)?.slug;
            }

            for (const {slug, heading} of headings) {
                if (heading.getBoundingClientRect().top > offset + roundingTolerance) {
                    break;
                }

                activeSlug = slug;
            }

            return activeSlug;
        };

        const updateActiveHeading = (): void => {
            animationFrame = 0;
            setActive(getActiveSlug());
        };

        const scheduleUpdate = (): void => {
            if (!animationFrame) {
                animationFrame = requestAnimationFrame(updateActiveHeading);
            }
        };

        toggle.addEventListener(
            'click',
            () => {
                setOpen(!panel.hasAttribute('data-open'));
            },
            {signal},
        );

        navigation.addEventListener(
            'click',
            (event) => {
                const target = event.target;

                if (!(target instanceof Element)) {
                    return;
                }

                const link = target.closest<HTMLAnchorElement>('[data-heading-link]');

                if (!link) {
                    return;
                }

                setActive(link.dataset.headingLink);
                setOpen(false);
            },
            {signal},
        );

        document.addEventListener(
            'click',
            (event) => {
                const target = event.target;

                if (target instanceof Node && !navigation.contains(target)) {
                    setOpen(false);
                }
            },
            {signal},
        );

        window.addEventListener('scroll', scheduleUpdate, {
            passive: true,
            signal,
        });

        window.addEventListener('resize', scheduleUpdate, {signal});
        window.addEventListener('hashchange', scheduleUpdate, {signal});
        signal.addEventListener('abort', () => cancelAnimationFrame(animationFrame), {once: true});

        scheduleUpdate();
    };

    document.addEventListener('astro:page-load', () => {
        navigationController?.abort();
        navigationController = new AbortController();

        for (const navigation of document.querySelectorAll<HTMLElement>('.sidebar-navigation')) {
            initNavigation(navigation, navigationController.signal);
        }
    });
</script>
