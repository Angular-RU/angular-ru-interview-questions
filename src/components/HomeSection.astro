---
import HomeCard from './HomeCard.astro';

type Card = {
    href: string;
    title: string;
    description: string;
    category: string;
    icon: string;
    count?: number;
};

type Props = {
    id?: string;
    eyebrow: string;
    title: string;
    linkHref?: string;
    linkText?: string;
    items: Card[];
};

const { id, eyebrow, title, linkHref, linkText, items } = Astro.props;

const withBase = (path: string) =>
    `${import.meta.env.BASE_URL}${path.replace(/^\/+/, '')}`;
---

<section class="section" id={id}>
    <header class="section-header">
        <div>
            <p class="eyebrow">{eyebrow}</p>
            {title ? <h2>{title}</h2> : ''}
        </div>

        {
            linkText && linkHref && (
                <a class="section-link" href={withBase(linkHref)}>{linkText}</a>
            )
        }
    </header>

    <div class="grid">
        {
            items.map((item) => (
                <HomeCard
                    href={item.href}
                    title={item.title}
                    description={item.description}
                    category={item.category}
                    icon={item.icon}
                    count={item.count}
                />
            ))
        }
    </div>
</section>

<style>
    .section {
        scroll-margin-top: 28px;
        margin-top: 86px;
    }

    .section:first-child {
        margin-top: 0;
    }

    .section-header {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 24px;
        margin-bottom: 30px;
    }

    .eyebrow {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 0 0 14px;
        color: #2f73ff;
        font-size: 0.95rem;
        font-weight: 900;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }

    .eyebrow::after {
        content: '';
        width: min(24vw, 260px);
        height: 1px;
        background: linear-gradient(90deg, #8bb8ff, rgb(139 184 255 / 0%));
    }

    h2 {
        margin: 0;
        color: #071942;
        font-size: clamp(2.2rem, 4vw, 3.25rem);
        line-height: 1.05;
        letter-spacing: 0;
    }

    .section-link {
        display: inline-flex;
        min-height: 42px;
        align-items: center;
        justify-content: center;
        padding: 0 18px;
        border: 1px solid #cbd9ed;
        border-radius: 12px;
        color: #10234b;
        background: rgb(255 255 255 / 76%);
        font-size: 0.95rem;
        font-weight: 900;
        text-decoration: none;
        box-shadow: 0 10px 24px rgb(27 74 138 / 7%);
    }

    .section-link:hover {
        border-color: #8bb8ff;
        color: #2563eb;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 24px;
    }

    @media (max-width: 1000px) {
        .grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (max-width: 700px) {
        .section {
            margin-top: 56px;
        }

        .section-header {
            align-items: start;
            flex-direction: column;
        }

        .section-link {
            width: 100%;
        }

        .grid {
            grid-template-columns: 1fr;
        }
    }
</style>
