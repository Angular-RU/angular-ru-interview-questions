---
type Props = {
    href: string;
    title: string;
    description: string;
    category: string;
    icon?: string;
    count?: number;
};

const {href, title, description, category, icon, count} = Astro.props;

const withBase = (path: string) => {
    const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

    return `${base}${path.replace(/^\/+/, '')}`;
};

const formatQuestionCount = (count: number): string => {
    const mod10 = count % 10;
    const mod100 = count % 100;

    if (mod10 === 1 && mod100 !== 11) {
        return `${count} вопрос`;
    }

    if ([2, 3, 4].includes(mod10) && ![12, 13, 14].includes(mod100)) {
        return `${count} вопроса`;
    }

    return `${count} вопросов`;
};
---

<a
    class="card"
    href={withBase(href)}
>
    <div class="card-header">
        {
            icon ? (
                <span class="card-icon">
                    <img
                        src={withBase(icon)}
                        alt=""
                        loading="lazy"
                    />
                </span>
            ) : (
                <span
                    class="card-icon card-icon-fallback"
                    aria-hidden="true"
                >
                    ✦
                </span>
            )
        }

        <span class="badge">{category}</span>
    </div>

    <h3>{title}</h3>

    <p>{description}</p>

    <div class="card-footer">
        <span class="card-meta">
            {count !== undefined ? formatQuestionCount(count) : 'Практика'}
        </span>

        <span
            class="card-arrow"
            aria-hidden="true"
        >
            →
        </span>
    </div>
</a>

<style>
    .card {
        position: relative;
        display: flex;
        min-height: 260px;
        flex-direction: column;
        padding: 28px;
        border: 1px solid rgb(191 207 232 / 85%);
        border-radius: 20px;
        color: var(--text);
        background: radial-gradient(circle at 18% 16%, rgb(49 92 255 / 5%), transparent 9rem), #ffffff;
        text-decoration: none;
        box-shadow: 0 14px 40px rgb(15 23 42 / 5%);
        transition:
            transform 160ms ease,
            border-color 160ms ease,
            box-shadow 160ms ease;
    }

    .card:hover {
        transform: translateY(-4px);
        border-color: rgb(99 148 255 / 80%);
        box-shadow: 0 24px 60px rgb(49 92 255 / 13%);
    }

    .card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 28px;
    }

    .card-icon {
        display: flex;
        width: 56px;
        height: 56px;
        flex: 0 0 56px;
        align-items: center;
        justify-content: center;
        padding: 0;
        border: 1px solid #b9d8f7;
        border-radius: 18px;
        background: linear-gradient(135deg, #eff6ff, #dbeafe);
        box-shadow: inset 0 0 0 8px rgb(49 92 255 / 5%);
    }

    .card-icon img {
        width: 30px;
        height: 30px;
        object-fit: contain;
    }

    .card-icon-fallback {
        align-items: center;
        justify-content: center;
        color: #315cff;
        font-size: 1.5rem;
        font-weight: 900;
    }

    .badge {
        display: inline-flex;
        width: fit-content;
        align-items: center;
        border: 1px solid #bdd6ff;
        border-radius: 999px;
        background: #f3f8ff;
        color: #2563eb;
        font-size: 0.82rem;
        font-weight: 800;
        line-height: 1;
        padding: 7px 12px;
    }

    h3 {
        margin: 0 0 12px;
        color: #071537;
        font-size: clamp(1.45rem, 2vw, 1.85rem);
        line-height: 1.12;
        letter-spacing: 0;
    }

    p {
        margin: 0;
        color: #475569;
        font-size: 1rem;
        line-height: 1.55;
    }

    .card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-top: auto;
        padding-top: 28px;
    }

    .card-arrow {
        display: grid;
        width: 42px;
        height: 42px;
        place-items: center;
        border: 1px solid #b9d8f7;
        border-radius: 999px;
        color: #315cff;
        background: #eef7ff;
        font-size: 1.15rem;
        font-weight: 900;
        transition:
            transform 160ms ease,
            background 160ms ease,
            border-color 160ms ease;
    }

    .card:hover .card-arrow {
        transform: translateX(3px);
        border-color: #8bb8ff;
        background: #e0edff;
    }

    .card-meta {
        color: #64748b;
        font-size: 0.92rem;
        font-weight: 750;
    }

    .card-link {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: #315cff;
        font-size: 0.98rem;
        font-weight: 900;
    }

    .card-link::after {
        content: '';
        width: 18px;
        height: 9px;
        border-right: 2px solid currentColor;
        border-bottom: 2px solid currentColor;
        transform: skewX(-35deg);
    }
</style>
