---
import {ClientRouter} from 'astro:transitions';

import SidebarNavigation from '../components/SidebarNavigation.astro';
import SiteSearch from '../components/SiteSearch.astro';
import '../styles/global.css';

interface MarkdownHeading {
    readonly depth: number;
    readonly slug: string;
    readonly text: string;
}

interface Frontmatter {
    readonly title?: string;
    readonly description?: string;
}

interface Props {
    readonly title?: string;
    readonly description?: string;
    readonly frontmatter?: Frontmatter;
    readonly headings?: readonly MarkdownHeading[];
}

const {title: titleFromProps, description: descriptionFromProps, frontmatter, headings = []} = Astro.props;

const title = titleFromProps ?? frontmatter?.title ?? 'Angular RU Interview Questions';
const description =
    descriptionFromProps ?? frontmatter?.description ?? 'Вопросы и практические задания для подготовки разработчиков';

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname.replace(/\/$/, '');
const homeHref = `${basePath}/`;
const isHomePage = currentPath === basePath;
const showHomeLink = !isHomePage;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const pagefindPath = `${basePath}/pagefind`;
const searchEnabled = import.meta.env.PROD;
---

<!doctype html>
<html lang="ru">
    <head>
        <meta charset="utf-8" />
        <meta
            name="description"
            content={description}
        />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1.0"
        />
        <meta
            name="theme-color"
            content="#f6f8fb"
        />
        <meta
            property="og:title"
            content={title}
        />
        <meta
            property="og:description"
            content={description}
        />
        <meta
            property="og:type"
            content="website"
        />
        <meta
            property="og:url"
            content={canonicalUrl}
        />
        <meta
            property="og:locale"
            content="ru_RU"
        />
        <link
            rel="canonical"
            href={canonicalUrl}
        />
        {
            searchEnabled && (
                <link
                    rel="stylesheet"
                    href={`${pagefindPath}/pagefind-component-ui.css`}
                />
            )
        }
        {
            !isHomePage && (
                <meta
                    data-pagefind-filter="page[content]"
                    content={currentPath}
                />
            )
        }
        <title>{title}</title>
        <ClientRouter />
        {
            searchEnabled && (
                <script
                    type="module"
                    src={`${pagefindPath}/pagefind-component-ui.js`}
                />
            )
        }
    </head>

    <body>
        <main class="page">
            <article
                class="content"
                data-pagefind-body
            >
                {!isHomePage && <SiteSearch pagePath={currentPath} />}

                <SidebarNavigation
                    headings={headings}
                    homeHref={homeHref}
                    showHomeLink={showHomeLink}
                    title={title}
                />

                <slot />
            </article>
        </main>

        <script>
            interface PagefindModalElement extends HTMLElement {
                close(): void;
            }

            declare global {
                interface Window {
                    PagefindComponents?: {
                        getInstanceManager(): {
                            getInstance(name: string): {
                                triggerFilter(name: string, values: ReadonlyArray<string>): void;
                            };
                            removeInstance(name: string): void;
                        };
                    };
                }
            }

            document.addEventListener('astro:before-swap', () => {
                window.PagefindComponents?.getInstanceManager().removeInstance('default');
            });

            document.addEventListener('astro:page-load', () => {
                const pagePath = document.querySelector<HTMLElement>('.site-search')?.dataset.pagePath;
                const searchModal = document.querySelector<PagefindModalElement>('.site-search pagefind-modal');

                if (pagePath) {
                    window.PagefindComponents?.getInstanceManager()
                        .getInstance('default')
                        .triggerFilter('page', [pagePath]);
                }

                searchModal?.addEventListener('click', (event) => {
                    const resultLink =
                        event.target instanceof Element ? event.target.closest<HTMLAnchorElement>('a[href]') : null;

                    if (!resultLink) {
                        return;
                    }

                    const resultUrl = new URL(resultLink.href);
                    const isCurrentPageResult =
                        resultUrl.origin === window.location.origin &&
                        resultUrl.pathname === window.location.pathname &&
                        resultUrl.search === window.location.search &&
                        Boolean(resultUrl.hash);

                    if (!isCurrentPageResult) {
                        return;
                    }

                    const dialog = searchModal.querySelector('dialog');

                    if (!dialog) {
                        return;
                    }

                    event.preventDefault();
                    dialog.addEventListener(
                        'close',
                        () => {
                            window.location.hash = resultUrl.hash;
                            document.getElementById(decodeURIComponent(resultUrl.hash.slice(1)))?.scrollIntoView();
                        },
                        {once: true},
                    );
                    searchModal.close();
                });
            });
        </script>
    </body>
</html>
