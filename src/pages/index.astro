---
import '../styles/home.css';

import Layout from '../layouts/Layout.astro';
import HeroSpaceIllustration from '../components/HeroSpaceIllustration.astro';
import HomeSection from '../components/HomeSection.astro';
import SiteSearch from '../components/SiteSearch.astro';
import {examples} from '../data/examples';

type MarkdownModule = {
    frontmatter?: {
        title?: string;
        description?: string;
        category?: string;
        kind?: string;
        order?: number;
        icon?: string;
    };
};

type QuestionCard = {
    href: string;
    title: string;
    description: string;
    category: string;
    kind: string;
    order: number;
    icon: string;
    count: number;
};

const markdownModules = import.meta.glob<MarkdownModule>('./**/index.md', {
    eager: true,
});

const markdownSources = import.meta.glob<string>('./**/index.md', {
    eager: true,
    query: '?raw',
    import: 'default',
});

const iconBySlug: Record<string, string> = {
    angular: '/logos/angular.svg',
    architecture: '/logos/aws-app-mesh.svg',
    'databases-sql': '/logos/postgresql.svg',
    docker: '/logos/docker.svg',
    git: '/logos/git.svg',
    linux: '/logos/linux.svg',
    react: '/logos/react.svg',
    'system-design': '/logos/web-platform.svg',
    'state-management': '/logos/redux.svg',
    'frontend-architecture-patterns': '/logos/frontend-architecture.svg',
    javascript: '/logos/javascript.svg',
    typescript: '/logos/typescript.svg',
    'ui-ux': '/logos/figma.svg',
    'web-protocols': '/logos/json-schema-icon.svg',
    css: '/logos/css.svg',
    html: '/logos/html5.svg',
    integrations: '/logos/kafka-icon.svg',
    nodejs: '/logos/nodejs.svg',
    'operating-systems': '/logos/microsoft-windows-icon.svg',
    'computer-science': '/logos/computer-science.svg',
    'web-platform': '/logos/web-platform.svg',
    'browser-rendering': '/logos/browser.svg',
    browser: '/logos/browser.svg',
    http: '/logos/http.svg',
    qa: '/logos/playwright.svg',
    testing: '/logos/testing.svg',
    'career-teamwork': '/logos/soft-skills.svg',
};

const iconByCategory: Record<string, string> = {
    Backend: '/logos/nodejs.svg',
    'Базы данных': '/logos/computer-science.svg',
    Career: '/logos/soft-skills.svg',
    DevOps: '/logos/gitlab.svg',
    Engineering: '/logos/computer-science.svg',
    Fundamentals: '/logos/computer-science.svg',
    Frontend: '/logos/web-platform.svg',
    'System Design': '/logos/web-platform.svg',
    Архитектура: '/logos/web-platform.svg',
    Инфраструктура: '/logos/gitlab.svg',
    Карьера: '/logos/soft-skills.svg',
    'Основы и инструменты': '/logos/computer-science.svg',
};

const countQuestions = (source: string): number => {
    const summaryCount = source.match(/<summary[\s>]/gi)?.length ?? 0;

    if (summaryCount > 0) {
        return summaryCount;
    }

    return source.match(/<details[\s>]/gi)?.length ?? 0;
};

const titleFromPath = (path: string) => {
    const slug = path.replace('./', '').replace('/index.md', '').split('/').at(-1);

    return slug
        ?.split('-')
        .map((part) => part[0]?.toUpperCase() + part.slice(1))
        .join(' ');
};

const slugFromPath = (path: string) => path.replace('./', '').replace('/index.md', '').split('/').at(-1) ?? '';

const questionCards: QuestionCard[] = Object.entries(markdownModules)
    .map(([path, module]) => {
        const frontmatter = module.frontmatter ?? {};
        const slug = slugFromPath(path);

        const href = `/${path.replace('./', '').replace('/index.md', '/')}`;

        return {
            href,
            title: frontmatter.title ?? titleFromPath(path) ?? 'Untitled',
            description: frontmatter.description ?? 'Вопросы и ответы для подготовки.',
            category: frontmatter.category ?? 'Frontend',
            kind: frontmatter.kind ?? 'questions',
            order: frontmatter.order ?? 999,
            icon: frontmatter.icon ?? iconBySlug[slug] ?? iconByCategory[frontmatter.category ?? 'Frontend'] ?? '',
            count: countQuestions(markdownSources[path] ?? ''),
        };
    })
    .filter((item) => item.kind === 'questions')
    .sort((a, b) => a.order - b.order);

const questionSections = [
    {id: 'fundamentals', title: 'Основы и инструменты', category: 'Основы и инструменты'},
    {id: 'frontend', title: 'Frontend', category: 'Frontend'},
    {id: 'backend', title: 'Backend', category: 'Backend'},
    {id: 'architecture', title: 'Архитектура', category: 'Архитектура'},
    {id: 'infrastructure', title: 'Инфраструктура', category: 'Инфраструктура'},
    {id: 'career', title: 'Карьера', category: 'Карьера'},
].map((section) => ({
    ...section,
    items: questionCards.filter((card) => card.category === section.category),
}));

const navigationItems = [...questionSections.map(({id, title}) => ({id, title})), {id: 'demos', title: 'Демки'}];

const exampleCards = examples.slice().sort((a, b) => a.order - b.order);
---

<Layout
    title="Interview Handbook"
    description="Вопросы и практические задания для подготовки разработчиков"
>
    <div
        class="home"
        data-home-page
    >
        <section
            class="hero"
            aria-labelledby="home-title"
        >
            <div class="hero-content">
                <h1
                    id="home-title"
                    class="hero-title"
                >
                    Interview Handbook
                </h1>
                <p class="hero-eyebrow">Готовимся уверенно и проходим собеседования успешно</p>
                <p class="hero-lead">
                    Вопросы, ответы и практические демо для подготовки разработчиков: инженерные основы, Frontend,
                    Backend, архитектура, инфраструктура и soft skills.
                </p>

                <SiteSearch
                    placeholder="Найти вопрос, тему или технологию..."
                    variant="hero"
                />

                <div
                    class="hero-navigation"
                    aria-label="Разделы"
                >
                    {
                        navigationItems.map((item) => (
                            <a
                                class="navigation-chip"
                                href={`#${item.id}`}
                            >
                                {item.title}
                            </a>
                        ))
                    }
                </div>
            </div>

            <div
                class="hero-visual"
                aria-hidden="true"
            >
                <HeroSpaceIllustration />
            </div>
        </section>

        {
            questionSections.map((section) => (
                <HomeSection
                    id={section.id}
                    eyebrow={section.title}
                    title=""
                    items={section.items}
                />
            ))
        }

        <HomeSection
            id="demos"
            eyebrow="Демки"
            title=""
            items={exampleCards}
        />
    </div>
</Layout>
