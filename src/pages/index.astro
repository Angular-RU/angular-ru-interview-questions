---
import '../styles/home.css';

import Layout from '../layouts/Layout.astro';
import HeroSpaceIllustration from '../components/HeroSpaceIllustration.astro';
import HomeSection from '../components/HomeSection.astro';
import {examples} from '../data/examples';

type MarkdownModule = {
    frontmatter?: {
        title?: string;
        description?: string;
        category?: string;
        kind?: string;
        order?: number;
        icon?: string;
    };
};

type QuestionCard = {
    href: string;
    title: string;
    description: string;
    category: string;
    kind: string;
    order: number;
    icon: string;
    count: number;
};

const markdownModules = import.meta.glob<MarkdownModule>('./**/index.md', {
    eager: true,
});

const markdownSources = import.meta.glob<string>('./**/index.md', {
    eager: true,
    query: '?raw',
    import: 'default',
});

const iconBySlug: Record<string, string> = {
    angular: '/logos/angular.svg',
    react: '/logos/react.svg',
    javascript: '/logos/javascript.svg',
    typescript: '/logos/typescript.svg',
    css: '/logos/css.svg',
    html: '/logos/html5.svg',
    nodejs: '/logos/nodejs.svg',
    'computer-science': '/logos/computer-science.svg',
    'web-platform': '/logos/web-platform.svg',
    'browser-rendering': '/logos/browser.svg',
    browser: '/logos/browser.svg',
    http: '/logos/http.svg',
    testing: '/logos/testing.svg',
    'career-teamwork': '/logos/soft-skills.svg',
};

const iconByCategory: Record<string, string> = {
    Backend: '/logos/nodejs.svg',
    Career: '/logos/soft-skills.svg',
    Engineering: '/logos/computer-science.svg',
    'Engineering Fundamentals': '/logos/computer-science.svg',
    Frontend: '/logos/web-platform.svg',
};

const countQuestions = (source: string): number => {
    const summaryCount = source.match(/<summary[\s>]/gi)?.length ?? 0;

    if (summaryCount > 0) {
        return summaryCount;
    }

    return source.match(/<details[\s>]/gi)?.length ?? 0;
};

const titleFromPath = (path: string) => {
    const slug = path.replace('./', '').replace('/index.md', '').split('/').at(-1);

    return slug
        ?.split('-')
        .map((part) => part[0]?.toUpperCase() + part.slice(1))
        .join(' ');
};

const slugFromPath = (path: string) => path.replace('./', '').replace('/index.md', '').split('/').at(-1) ?? '';

const questionCards: QuestionCard[] = Object.entries(markdownModules)
    .map(([path, module]) => {
        const frontmatter = module.frontmatter ?? {};
        const slug = slugFromPath(path);

        const href = `/${path.replace('./', '').replace('/index.md', '/')}`;

        return {
            href,
            title: frontmatter.title ?? titleFromPath(path) ?? 'Untitled',
            description: frontmatter.description ?? 'Вопросы и ответы для подготовки.',
            category: frontmatter.category ?? 'Frontend',
            kind: frontmatter.kind ?? 'questions',
            order: frontmatter.order ?? 999,
            icon: frontmatter.icon ?? iconBySlug[slug] ?? iconByCategory[frontmatter.category ?? 'Frontend'] ?? '',
            count: countQuestions(markdownSources[path] ?? ''),
        };
    })
    .filter((item) => item.kind === 'questions')
    .sort((a, b) => a.order - b.order);

const exampleCards = examples.slice().sort((a, b) => a.order - b.order);
---

<Layout
    title="Angular RU Interview Questions"
    description="Вопросы и практические задания для подготовки frontend-разработчиков"
>
    <div
        class="home"
        data-home-page
    >
        <section
            class="hero"
            aria-labelledby="home-title"
        >
            <div class="hero-content">
                <h1
                    id="home-title"
                    class="hero-title"
                >
                    Frontend Interview Questions
                </h1>
                <p class="hero-eyebrow">Готовимся уверенно и проходим собеседования успешно</p>
                <p class="hero-lead">
                    Вопросы, ответы и практические демо для подготовки frontend-разработчиков: Computer Science, Web
                    Platform, CSS, JavaScript, TypeScript, Angular, React, тестирование, архитектура и soft skills.
                </p>

                <div class="hero-actions">
                    <a
                        class="primary-action"
                        href="#theory"
                    >
                        Начать подготовку
                    </a>
                    <a
                        class="secondary-action"
                        href="#practice"
                    >
                        Смотреть практику
                    </a>
                </div>
            </div>

            <div
                class="hero-visual"
                aria-hidden="true"
            >
                <HeroSpaceIllustration />
            </div>
        </section>

        <HomeSection
            id="theory"
            eyebrow="Теория"
            title=""
            items={questionCards}
        />

        <HomeSection
            id="practice"
            eyebrow="Практика"
            title=""
            items={exampleCards}
        />
    </div>
</Layout>
