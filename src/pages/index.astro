---
import Layout from '../layouts/Layout.astro';
import HomeSection from '../components/HomeSection.astro';
import { examples } from '../data/examples';

type MarkdownModule = {
    frontmatter?: {
        title?: string;
        description?: string;
        category?: string;
        kind?: string;
        order?: number;
    };
};

const modules = import.meta.glob<MarkdownModule>('./**/index.md', {
    eager: true,
});

const titleFromPath = (path: string) => {
    const slug = path
        .replace('./', '')
        .replace('/index.md', '')
        .split('/')
        .at(-1);

    return slug
        ?.split('-')
        .map((part) => part[0]?.toUpperCase() + part.slice(1))
        .join(' ');
};

const questionCards = Object.entries(modules)
    .map(([path, module]) => {
        const frontmatter = module.frontmatter ?? {};

        const href = `/${path.replace('./', '').replace('/index.md', '/')}`;

        return {
            href,
            title: frontmatter.title ?? titleFromPath(path) ?? 'Untitled',
            description: frontmatter.description ?? 'Вопросы и ответы для подготовки.',
            category: frontmatter.category ?? 'Frontend',
            kind: frontmatter.kind ?? 'questions',
            order: frontmatter.order ?? 999,
        };
    })
    .filter((item) => item.kind === 'questions')
    .sort((a, b) => a.order - b.order);

const exampleCards = examples
    .slice()
    .sort((a, b) => a.order - b.order);
---

<Layout
    title="Angular RU Interview Questions"
    description="Вопросы и практические задания для подготовки frontend-разработчиков"
>
    <div class="home">
        <section class="hero">
            <p class="eyebrow">Angular RU</p>
            <h1>Frontend Interview Questions</h1>
            <p class="lead">
                Вопросы, ответы и практические демо для подготовки frontend-разработчиков:
                Computer Science, Web Platform, CSS, JavaScript, TypeScript, Angular,
                React, тестирование, архитектура и soft skills.
            </p>
        </section>

        <HomeSection
            eyebrow="Теория"
            title="Вопросы"
            linkText="Смотреть все вопросы"
            linkHref="/questions/"
            items={questionCards}
        />

        <HomeSection
            eyebrow="Демо"
            title="Практика"
            linkText="Смотреть все примеры"
            linkHref="/examples/"
            items={exampleCards}
        />
    </div>
</Layout>

<style>
    :global(body) {
        margin: 0;
        background: #f6f8fb;
        color: #172033;
        font-family:
            Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
            "Segoe UI", sans-serif;
    }

    .home {
        width: min(100% - 48px, 1440px);
        margin: 0 auto;
        padding: 56px 0 80px;
    }

    .hero {
        max-width: 900px;
        margin-bottom: 72px;
    }

    .eyebrow {
        margin: 0 0 12px;
        color: #1264c3;
        font-size: 0.95rem;
        font-weight: 900;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }

    h1 {
        margin: 0;
        color: #172033;
        font-size: clamp(3rem, 7vw, 6.5rem);
        line-height: 0.95;
        letter-spacing: -0.075em;
    }

    .lead {
        max-width: 760px;
        margin: 28px 0 0;
        color: #5f6b7a;
        font-size: clamp(1.15rem, 2vw, 1.45rem);
        line-height: 1.55;
    }

    @media (max-width: 700px) {
        .home {
            width: min(100% - 28px, 1440px);
            padding: 32px 0 56px;
        }

        .hero {
            margin-bottom: 48px;
        }
    }
</style>
