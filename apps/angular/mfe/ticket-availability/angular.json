{
    "$schema": "../../../../node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "cli": {
        "packageManager": "npm"
    },
    "newProjectRoot": "projects",
    "projects": {
        "ticket-availability": {
            "projectType": "application",
            "schematics": {},
            "root": "",
            "sourceRoot": "src",
            "prefix": "app",
            "architect": {
                "build": {
                    "builder": "@angular-architects/native-federation:build",
                    "options": {
                        "cacheExternalArtifacts": true
                    },
                    "configurations": {
                        "production": {
                            "target": "ticket-availability:esbuild:production",
                            "ssr": true
                        },
                        "development": {
                            "target": "ticket-availability:esbuild:development",
                            "dev": true
                        },
                        "public": {
                            "target": "ticket-availability:esbuild:public",
                            "ssr": false
                        }
                    },
                    "defaultConfiguration": "production"
                },
                "serve": {
                    "builder": "@angular-architects/native-federation:build",
                    "options": {
                        "target": "ticket-availability:serve-original:development",
                        "rebuildDelay": 500,
                        "cacheExternalArtifacts": true,
                        "dev": true,
                        "devServer": true,
                        "port": 0
                    }
                },
                "test": {
                    "builder": "@angular/build:unit-test"
                },
                "esbuild": {
                    "builder": "@angular/build:application",
                    "options": {
                        "outputPath": "dist/ticket-availability",
                        "index": "src/index.html",
                        "browser": "src/main.ts",
                        "tsConfig": "tsconfig.app.json",
                        "assets": [
                            {
                                "glob": "**/*",
                                "input": "public"
                            }
                        ],
                        "styles": ["src/styles.css"],
                        "security": {
                            "allowedHosts": ["localhost"]
                        },
                        "polyfills": ["es-module-shims"]
                    },
                    "configurations": {
                        "production": {
                            "server": "src/main.server.ts",
                            "outputMode": "server",
                            "ssr": {
                                "entry": "src/server.ts"
                            },
                            "budgets": [
                                {
                                    "type": "initial",
                                    "maximumWarning": "500kB",
                                    "maximumError": "1MB"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "4kB",
                                    "maximumError": "8kB"
                                }
                            ],
                            "outputHashing": "all"
                        },
                        "development": {
                            "optimization": false,
                            "extractLicenses": false,
                            "sourceMap": true
                        },
                        "public": {
                            "baseHref": "/interview/examples/angular/mfe/ticket-availability/",
                            "outputPath": {
                                "base": "../../../../public/examples/angular/mfe/ticket-availability/",
                                "browser": ""
                            },
                            "optimization": true,
                            "outputHashing": "all"
                        }
                    },
                    "defaultConfiguration": "production"
                },
                "serve-original": {
                    "builder": "@angular/build:dev-server",
                    "configurations": {
                        "production": {
                            "buildTarget": "ticket-availability:esbuild:production"
                        },
                        "development": {
                            "buildTarget": "ticket-availability:esbuild:development"
                        }
                    },
                    "defaultConfiguration": "development",
                    "options": {
                        "port": 4202
                    }
                }
            }
        }
    }
}
