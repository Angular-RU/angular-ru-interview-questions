    "bugs": {
        "url": "https://github.com/Angular-RU/angular-ru-interview-questions/issues"
    },
    "workspaces": [
        "examples/*/*",
        "examples/*/*/*"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Angular-RU/angular-ru-interview-questions.git"
    },
    "type": "module",
    "license": "MIT",
    "author": "angular-ru@yandex.ru",
    "scripts": {
        "build:old": "tsx scripts/build.ts",
        "build:site": "tsx site/scripts/build.ts",
        "build:examples": "tsx examples/scripts/build.ts",
        "dev": "astro dev",
        "build": "astro build",
        "preview": "astro preview",
        "astro": "astro",
        "format": "prettier !package-lock.json . --ignore-path .gitignore --write"
    },
    "dependencies": {
        "@types/node": "26.1.0",
        "prettier": "3.8.4",
        "tsx": "4.20.6"
    },
    "devDependencies": {
        "@astrojs/react": "6.0.1",
        "@tailwindcss/vite": "4.3.2",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "astro": "7.0.6",
        "highlight.js": "11.11.1",
        "markdown-it": "14.2.0",
        "markdown-it-anchor": "9.2.0",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "sharp": "^0.35.3",
        "tailwindcss": "4.3.2"
    }
